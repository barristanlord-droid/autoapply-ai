# =============================================================================
# Careerly - API Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].

# --- App ---
APP_NAME=Careerly
APP_VERSION=0.1.0
DEBUG=true                          # Set to false in production
API_PREFIX=/api/v1

# --- Database ---
# [REQUIRED] SQLite for development, PostgreSQL for production
# Dev:  sqlite+aiosqlite:///./careerly.db
# Prod: postgresql+asyncpg://user:password@host:5432/careerly
DATABASE_URL=sqlite+aiosqlite:///./careerly.db
DATABASE_ECHO=false                 # Set to true to log SQL queries

# --- Redis ---
# [REQUIRED] Used for caching and rate limiting
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# [REQUIRED] Secret key for JWT signing. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# --- OAuth (optional for local dev) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- OpenAI ---
# [REQUIRED] Your OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- AWS S3 (optional for local dev) ---
# Used for resume file storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=careerly-resumes

# --- Stripe (optional for local dev) ---
# Used for subscription billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# --- Celery ---
# Used for background job processing
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Frontend ---
# [REQUIRED] URL of the frontend app (for CORS)
FRONTEND_URL=http://localhost:3001
