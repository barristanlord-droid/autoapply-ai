{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--port", "8006", "--root-path", "/api/v1"],
      "port": 8006,
      "cwd": "apps/api"
    },
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3001"],
      "port": 3001,
      "autoPort": false,
      "cwd": "apps/web"
    }
  ]
}
